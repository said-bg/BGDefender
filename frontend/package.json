{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "start:e2e": "next start -p 3100",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:clean": "node -e \"require('fs').rmSync('test-results',{recursive:true,force:true});\"",
    "test:e2e:watch": "playwright test --watch",
    "test:e2e:ui": "playwright test --ui",
    "posttest:e2e": "npm run test:e2e:clean"
  },
  "dependencies": {
    "@tiptap/extension-document": "^3.20.0",
    "@tiptap/extension-hard-break": "^3.20.0",
    "@tiptap/extension-list": "^3.20.0",
    "@tiptap/extension-paragraph": "^3.20.0",
    "@tiptap/extension-text": "^3.20.0",
    "@tiptap/extension-text-style": "^3.20.0",
    "@tiptap/extensions": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "axios": "^1.13.6",
    "i18next": "^25.8.19",
    "i18next-browser-languagedetector": "^8.2.1",
    "juice": "^11.1.1",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.8",
    "reactjs-tiptap-editor": "^1.0.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
